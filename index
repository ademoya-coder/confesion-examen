      .res-prayer { background:var(--gold-bg); border-color:var(--gold-border); color:var(--ink); }
      .res-step { background:var(--card); border-color:var(--line-soft); }
      .res-example { background:var(--bg-2); border-color:var(--line-soft); color:var(--muted); }
      /* Profile */
      .profile-card { background:var(--card); border-color:var(--line-soft); }
      .profile-card:hover { background:var(--gold-bg); border-color:var(--gold-border); }
      .profile-card.selected { background:var(--gold-bg); border-color:var(--gold-border); }
      .profile-note { background:var(--card-2); border-color:var(--line-soft); }
      /* Resource buttons */
      .res-btn { background:var(--card); border-color:var(--line-soft); }
      .faq-row-btn { background:var(--card); border-color:var(--line-soft); }
      .faq-row-btn:hover { background:var(--card-2); border-color:var(--line); }
      /* Progress */
      .progress { background:var(--bg-2); border-color:var(--line-soft); }
      .meta .box { background:var(--bg-2); border-color:var(--line-soft); }
      .legend span { background:var(--card-2); border-color:var(--line-soft); }
      /* Danger zone */
      .danger-zone { background:var(--terra-bg); border-color:rgba(139,74,42,.25); }
      .danger-zone .danger-label { color:var(--terra); }
      /* Skip hint */
      .skip-hint { background:var(--card-2); border-color:var(--line-soft); }
      /* Misc */
      .side-note { background:var(--bg-2); border-color:var(--line-soft); }
      .checkline { background:var(--gold-bg); border-color:rgba(200,148,10,.22); }
      details.terms { background:var(--card-2); border-color:var(--line-soft); }
      details.terms summary { background:var(--bg-2); color:var(--ink); }
      .practice-preview { background:var(--bg-2); border-color:var(--gold-border); }
      .choice-btn { background:var(--card); border-color:var(--line-soft); }
      #mobileNavBar { background:rgba(26,31,39,.97); border-color:var(--line); }
      .modal-dialog { background:var(--card); border-color:var(--line); }
      .footer-note { border-color:var(--line-soft); }
    }

    /* ===== PROFILE SELECTION SCREEN ===== */
    #profilePanel{background:var(--bg)}
    .profile-welcome{
      background:linear-gradient(150deg,#1A2535 0%,#243346 55%,#2D3E52 100%);
