    .details.open{max-height:2000px;opacity:1}

    /* ===== TOAST NOTIFICATIONS ===== */
    #toastContainer{
      position:fixed;bottom:90px;left:50%;transform:translateX(-50%);
      z-index:9999;display:flex;flex-direction:column;align-items:center;gap:8px;
      pointer-events:none;
    }
    .toast{
      padding:11px 20px;border-radius:12px;font-size:.90rem;font-weight:500;
