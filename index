    // ===== RESOURCE PANEL NAVIGATION =====
    function showResourcePanel(name) {
      const panelMap = { antes: 'resAntes', como: 'resComo', despues: 'resDespues', faq: 'resFaq' };
      const key = panelMap[name];
      if (!key || !panels[key]) return;
      transitionTo(() => {
        currentView = 'resource';
        hideAllPanels();
        panels[key].classList.remove('hidden');
        // Reset all details (except first in despues which is open by design)
        panels[key].querySelectorAll('details').forEach((d, i) => {
          d.open = (name === 'despues' && i === 0);
        });
        if (typeof applyI18n === 'function') applyI18n(currentLang);
        updateMobileNavResource();
      });
    }

    function hideResourcePanel() {
      transitionTo(() => {
        currentView = 'profile';
        document.body.classList.remove('exam-mode');
        hideAllPanels();
        panels.profile.classList.remove('hidden');
        updateMobileNav();
      });
    }

    function updateMobileNavResource() {
      const mobileStep = document.getElementById('mobileStep');
      const backBtn  = document.getElementById('mobileBack');
      const nextBtn  = document.getElementById('mobileNext');
      const mobileTimerEl = document.getElementById('mobileTimer');
      if (mobileTimerEl) mobileTimerEl.classList.add('hidden-val');
      if (mobileStep) mobileStep.textContent = {es:'Recursos',en:'Resources',pt:'Recursos'}[currentLang]||'Recursos';
      if (backBtn) {
        backBtn.style.display = '';
        backBtn.textContent = {es:'← Volver',en:'← Back',pt:'← Voltar'}[currentLang]||'← Volver';
        backBtn.onclick = () => hideResourcePanel();
      }
      if (nextBtn) {
        const hasProfile = !!userProfile;
        nextBtn.disabled = false;
        nextBtn.className = 'mobile-nav-btn primary';
        nextBtn.textContent = hasProfile
          ? {es:'Continuar al examen →',en:'Continue to exam →',pt:'Continuar para o exame →'}[currentLang]||'Continuar →'
          : {es:'Elegir perfil →',en:'Choose profile →',pt:'Escolher perfil →'}[currentLang]||'Elegir perfil →';
        nextBtn.onclick = () => {
          if (hasProfile) { hideResourcePanel(); setTimeout(() => confirmProfile(), 200); }
          else hideResourcePanel();
        };
      }
      updateTopProgress();
    }

