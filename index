      cursor:pointer;transition:.15s;
    }
    .gpill:hover{background:var(--gold-bg);border-color:var(--gold-border);color:var(--gold)}
    .gpill.active{background:var(--accent);color:#fff;border-color:var(--accent)}
    .gpill.active-ok{background:var(--ok);color:#fff;border-color:var(--ok)}
    .gpill.active-warn{background:var(--gold);color:#fff;border-color:var(--gold)}

    /* ===== RESULTS DANGER ZONE ===== */
