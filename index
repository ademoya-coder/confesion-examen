    function applyLang(lang) {
      const t = I18N[lang] || I18N['es'];
      currentLang = lang;
      localStorage.setItem('ec_lang', lang);

      // Hero
      const heroH1 = document.querySelector('.hero h1');
      if (heroH1) heroH1.innerHTML = t.heroTitle + '<br><span style="color:var(--gold-light);font-style:italic">' + t.heroSubtitle + '</span>';
      const heroPFirst = document.querySelector('.hero > .hero-grid > div:last-child > p');
      if (heroPFirst) heroPFirst.textContent = t.heroTagline;
      const heroSlimNameEl = document.getElementById('heroSlimName');
      if (heroSlimNameEl) heroSlimNameEl.textContent = t.heroTitle || 'Examen de conciencia';
      const slimMenuEl = document.getElementById('slimMenuBtn');
      if (slimMenuEl) slimMenuEl.textContent = '↺ ' + ({es:'Reiniciar',en:'Restart',pt:'Reiniciar'}[lang]||'Reiniciar');

      // Profile panel
      ['profileKicker','profileTitle','profileSubtitle',
       'profileAgeMarried','profileLabelMarried',
       'profileAgeSingle','profileLabelSingle',
       'profileAgeTeen','profileLabelTeen',
       'profileNote'
      ].forEach(id => {
        const el = document.getElementById(id);
        if (el && t[id]) el.textContent = t[id];
      });
      const btnCont = document.getElementById('profileContinue');
      if (btnCont) btnCont.textContent = t.profileContinue;

      // Fundamento section
      ['fundamentoKicker','fundamentoTitle','fundamentoRef'].forEach(id => {
        const el = document.getElementById(id);
        if (el && t[id]) el.textContent = t[id];
      });

      // Footer
      const footerEl = document.getElementById('footerNote');
      if (footerEl) footerEl.innerHTML = t.footerNote;

      // Active lang button highlight (full hero)
      ['es','en','pt'].forEach(l => {
        const lb = document.getElementById('lbtn-' + l);
        if (lb) lb.classList.toggle('active', l === lang);
        const slb = document.getElementById('slim-lbtn-' + l);
        if (slb) slb.classList.toggle('active', l === lang);
      });

      // Translate all panel content
      if (typeof applyI18n === 'function') applyI18n(lang);
      // Update mobile nav bottom bar immediately
      if (typeof updateMobileNav === 'function') updateMobileNav();
      // Re-render sources section
      if (typeof renderFuentes === 'function') renderFuentes();
      // Re-render top progress strip
      if (typeof updateTopProgress === 'function') updateTopProgress();
      // Update sections to match new language
      if (typeof getSections === 'function') sections = getSections(userProfile, lang);
      // Re-render TOC with translated labels
      if (typeof renderTOC === 'function') renderTOC();
      // Re-render current exam section immediately if in exam
      if (currentView === 'exam' && typeof showExam === 'function') showExam(current);
      // Re-render results if in results view
      if (currentView === 'results' && typeof buildResults === 'function') buildResults();
    }

