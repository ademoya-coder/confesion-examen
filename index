        updatePracticeProgress();
        evaluatePractice();
        document.getElementById('practicePreview').innerHTML = '<div class="small muted" data-i18n="step2PreviewPrompt">Marca la pregunta para empezar.</div>';
      };

      updatePracticeProgress();
      evaluatePractice();
