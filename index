    function transformToConfession(text) {
      let t = text.replace(/^[¿]/, '').replace(/[?]+$/, '').trim();
      // Already past tense (teen questions like "Robé...", "Hice...", "Fallé...")
      if (/^[A-ZÁÉÍÓÚÑ]/.test(t) && !/^He\b|^Me he\b/i.test(t)) {
        if (!/[.!]$/.test(t)) t += '.';
        return t;
      }
      const CONJ = {
        'acostumbrado':'me acostumbré','alimentado':'alimenté','buscado':'busqué',
        'caído':'caí','callado':'callé','causado':'causé','cerrado':'cerré',
        'comulgado':'comulgué','compartido':'compartí','consentido':'consentí',
        'corregido':'corregí','cumplido':'cumplí','dañado':'dañé',
        'dejado':'dejé','descuidado':'descuidé','dudado':'dudé',
        'excluido':'excluí','expuesto':'me expuse','fallado':'fallé',
        'faltado':'falté','gastado':'gasté','guardado':'guardé',
        'hecho':'hice','herido':'herí','humillado':'humillé',
        'llevado':'llevé','mentido':'mentí','omitido':'omití',
        'pasado':'pasé','pedido':'pedí','permitido':'permití',
        'probado':'probé','puesto':'puse','rechazado':'rechacé',
        'revelado':'revelé','robado':'robé','sido':'fui',
        'tenido':'tuve','trabajado':'trabajé','tratado':'traté',
        'usado':'usé','vivido':'viví','abusado':'abusé',
        'actuado':'actué','arrastrado':'arrastré'
      };
      if (/^Me he /i.test(t)) {
        t = t.replace(/^Me he (\w+)/i, function(m, p) {
          var v = CONJ[p.toLowerCase()];
          if (!v) return 'Me ' + p;
          return v.startsWith('me ') ? v : 'Me ' + v;
        });
      } else if (/^He /i.test(t)) {
        t = t.replace(/^He (\w+)/i, function(m, p) {
          return CONJ[p.toLowerCase()] || p;
        });
      }
      t = t.charAt(0).toUpperCase() + t.slice(1);
      if (!/[.!]$/.test(t)) t += '.';
      return t;
    }
    function buildResults() {
      const resultList = document.getElementById('resultList');
      const entries = [];
      const activeSecs = getSections(userProfile, currentLang);
      activeSecs.forEach((sec) => {
        sec.questions.forEach((q, qIdx) => {
          const key = `${sec.id}_${qIdx}`;
          const item = state[key];
          if (item && item.checked) {
            // For EN/PT questions are already direct, skip Spanish verb conjugation
            const confession = currentLang === 'es' ? transformToConfession(q.text) : q.text.replace(/^[¿]/, '').replace(/[?]+$/, '').trim() + '.';
            const _gr = item.gravity ? gravityResult(item.gravity.knowledge, item.gravity.consent) : {text:'',tone:''};
            const gravBadge = _gr.text
              ? `<span style="display:inline-flex;align-items:center;padding:3px 9px;border-radius:999px;font-size:.78rem;font-weight:700;margin-top:6px;background:${_gr.tone === 'ok' ? 'var(--ok-bg)' : _gr.tone === 'warn' ? 'var(--gold-bg)' : 'var(--soft)'};color:${_gr.tone === 'ok' ? 'var(--ok)' : _gr.tone === 'warn' ? 'var(--gold)' : 'var(--accent)'}">${_gr.text}</span>` : '';
            const meta = [
              item.times && `${(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.freqTitle||'Frecuencia';})()}: ${item.times}`,
              item.note && `Circunstancia: ${item.note}`
            ].filter(Boolean).join(' · ');
            entries.push(`
              <div class="result-item">
                <div style="font-weight:700;line-height:1.45;color:var(--ink)">• ${confession}</div>
                <div style="font-size:.80rem;color:var(--muted);margin-top:3px">${sec.name}</div>
                ${gravBadge}
                ${meta ? `<div class="small muted" style="margin-top:4px;font-size:.80rem">${meta}</div>` : ''}
              </div>
            `);
          }
        });
      });
      resultList.innerHTML = entries.length
        ? entries.join('')
        : `<div class="result-item"><strong>Aún no has marcado nada.</strong><div class="small muted" style="margin-top:6px">Haz el examen con calma. No marques por marcar, pero tampoco te salgas por arriba.</div></div>`;
    }

    function stopTimer() {
      clearInterval(timerHandle);
      timerHandle = null;
    }

    function clearSection() {
      const sec = sections[current];
      sec.questions.forEach((_, qIdx) => delete state[`${sec.id}_${qIdx}`]);
      saveState();
      renderQuestions(sec);
    }

    function formatTimer() {
      const m = String(Math.floor(timerValue / 60)).padStart(2, '0');
      const s = String(timerValue % 60).padStart(2, '0');
      const display = `${m}:${s}`;
      document.getElementById('timer').textContent = display;
      const mnt = document.getElementById('mobileTimer');
      if (mnt) { mnt.textContent = display; mnt.classList.remove('hidden-val'); }
    }

    document.getElementById('startTimer').addEventListener('click', () => {
      if (timerHandle) return;
      document.getElementById('pauseTimer').classList.remove('hidden');
      document.getElementById('resetTimer').classList.remove('hidden');
      timerHandle = setInterval(() => {
        if (timerValue > 0) {
          timerValue--;
          formatTimer();
        } else {
          stopTimer();
          showToast((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.toastTimerDone||'Tiempo cumplido.';})(), 'warn', 5000);
        }
      }, 1000);
    });

    document.getElementById('pauseTimer').addEventListener('click', stopTimer);
    document.getElementById('resetTimer').addEventListener('click', () => { stopTimer(); timerValue = 25 * 60; formatTimer(); });

    document.getElementById('introBack').addEventListener('click', showProfileScreen);

    document.getElementById('beginExam').addEventListener('click', () => {
      if (!hasAcceptedTerms()) {
        const _tBE=(typeof T!=='undefined'&&T[currentLang])?T[currentLang]:T['es'];
        showModal(
          _tBE.step1TermsTitle||'Aviso de uso pastoral',
          _tBE.modalTermsBody||'Debes leer y aceptar el aviso de uso pastoral antes de comenzar.',
          [{ label: _tBE.modalUnderstood||'Entendido', cls: 'primary' }]
        );
        return;
      }
      showPractice();
    });

    document.getElementById('practiceBack').addEventListener('click', showIntro);
    document.getElementById('practiceNext').addEventListener('click', () => {
      if (!hasAcceptedTerms()) {
        showModal((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalTermsTitle||'Aviso pendiente';})(), (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalTermsBody||'Primero debes aceptar el aviso de uso pastoral.';})(), [
          { label: 'Ir al inicio', cls: 'primary', action: showIntro }
        ]);
        return;
      }
      if (!practiceState.done) {
        showModal('Ensayo incompleto', 'Completa el ensayo guiado antes de iniciar el examen. Puedes cargar un ejemplo con "Cargar un ejemplo bien hecho".', [
          { label: 'Continuar con el ensayo', cls: 'primary' }
        ]);
        return;
      }
      showExam(0);
    });
    document.getElementById('prevSection').addEventListener('click', () => {
      if (current > 0) showExam(current - 1);
      else showPractice();
    });
    document.getElementById('nextSection').addEventListener('click', () => {
      if (current < sections.length - 1) showExam(current + 1);
      else showResults();
    });
    document.getElementById('clearSection').addEventListener('click', () => {
      showModal(
        (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalClearSecTitle||'Limpiar esta sección';})(),
        (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalClearSecBody||'Se borrarán todas las respuestas de esta sección. Esta acción no se puede deshacer.';})(),
        [
          { label:(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalCancel||'Cancelar';})(), cls:'ghost' },
          { label:(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalClearSecConfirm||'Sí, limpiar';})(), cls:'danger', action:clearSection }
        ]
      );
    });
    document.getElementById('resultsBack').addEventListener('click', () => showExam(sections.length - 1));
    document.getElementById('toContrition').addEventListener('click', showContrition);
    document.getElementById('contritionBack').addEventListener('click', showResults);
    document.getElementById('toAfter').addEventListener('click', showAfter);
    document.getElementById('afterBack').addEventListener('click', showContrition);
    document.getElementById('restartFlow').addEventListener('click', () => {
      practiceState.done = false;
      Object.keys(state).forEach(key => delete state[key]);
      try { localStorage.removeItem('ec_state'); } catch(e) {}
      showProfileScreen();
    });

    document.getElementById('copyList').addEventListener('click', async () => {
      const entries = [];
      sections.forEach((sec) => {
        sec.questions.forEach((q, qIdx) => {
          const key = `${sec.id}_${qIdx}`;
          const item = state[key];
          if (item && item.checked) {
            const _grCopy = item.gravity ? gravityResult(item.gravity.knowledge, item.gravity.consent) : {text:''};
            const extra = [_grCopy.text, item.times && `frecuencia: ${item.times}`, item.note && `${(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.noteTitle||'Circunstancia';})()}: ${item.note}`].filter(Boolean).join(' · ');
            entries.push(`- ${q.text}${extra ? ` (${extra})` : ''}`);
          }
        });
      });
      const _tCL=(typeof T!="undefined"&&T[currentLang])?T[currentLang]:T["es"]; const text = entries.length ? `${_tCL.step4Title||"Mi lista para la confesión"}\n\n${entries.join("\n")}` : (_tCL.toastNothingMarked||"Aún no hay elementos marcados.");
      try {
        await navigator.clipboard.writeText(text);
        showToast((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.toastCopied||'Lista copiada.';})(), 'ok');
      } catch(e) {
        showToast((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.toastCopyFail||'No se pudo copiar.';})(), 'warn');
      }
    });

    document.getElementById('printPage').addEventListener('click', () => window.print());

    document.getElementById('restartFromExam').addEventListener('click', () => {
      showModal(
        (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalRestartTitle||'Reiniciar el examen';})(),
        (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalRestartBody||'Volverás al inicio y perderás el progreso actual.';})(),
        [
          { label:(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalCancel||'Cancelar';})(), cls:'ghost' },
          { label:(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalRestartConfirm||'Sí, reiniciar';})(), cls:'danger', action:() => {
            Object.keys(state).forEach(key => delete state[key]);
            try { localStorage.removeItem('ec_state'); } catch(e) {}
            stopTimer();
            timerValue = 25 * 60;
            formatTimer();
            showProfileScreen();
          }}
        ]
      );
    });

    document.getElementById('clearAll').addEventListener('click', () => {
      showModal(
        (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalClearAllTitle||'Borrar todo el examen';})(),
        (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalClearAllBody||'Esto eliminará todas tus respuestas. Esta acción no se puede deshacer.';})(),
        [
          { label:(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalCancel||'Cancelar';})(), cls:'ghost' },
          { label:(()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalClearAllConfirm||'Sí, borrar todo';})(), cls:'danger', action:() => {
            Object.keys(state).forEach(key => delete state[key]);
            try { localStorage.removeItem('ec_state'); } catch(e) {}
            stopTimer();
            timerValue = 25 * 60;
            formatTimer();
            showToast((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.toastCleared||'Todo borrado.';})(), 'danger');
            showProfileScreen();
          }}
        ]
      );
    });

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      const installBtn = document.getElementById('installApp');
      if (installBtn) installBtn.classList.remove('hidden');
    });

    const installBtn = document.getElementById('installApp');
    if (installBtn) {
      installBtn.addEventListener('click', async () => {
        if (!deferredPrompt) return;
        deferredPrompt.prompt();
        await deferredPrompt.userChoice;
        deferredPrompt = null;
        installBtn.classList.add('hidden');
      });
    }

    window.addEventListener('appinstalled', () => {
      deferredPrompt = null;
      const installBtn = document.getElementById('installApp');
      if (installBtn) installBtn.classList.add('hidden');
    });

    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('./service-worker.js').catch(() => {});
      });
    }

    // Load persisted state
    loadState();

    // #4 — Show resume banner if saved session exists
    function checkSavedSession() {
      try {
        const raw = localStorage.getItem('ec_state');
        if (raw) {
          const saved = JSON.parse(raw);
          const hasChecked = Object.values(saved).some(v => v && v.checked);
          if (hasChecked) {
            const banner = document.createElement('div');
            banner.id = 'resumeBanner';
            Object.assign(banner.style, {position:'fixed',top:'0',left:'0',right:'0',zIndex:'200',background:'var(--ink-2)',color:'#fff',padding:'10px 16px',display:'flex',alignItems:'center',justifyContent:'space-between',gap:'12px',flexWrap:'wrap',fontSize:'.88rem',fontWeight:'500'});
            const msg = document.createElement('span');
            const _tBanner=(typeof T!=='undefined'&&T[currentLang])?T[currentLang]:T['es']; msg.textContent = _tBanner.resumeMsg||'Tienes un examen guardado en este dispositivo.';
            const btns = document.createElement('div');
            Object.assign(btns.style, {display:'flex',gap:'8px',flexShrink:'0'});
            const btnIgnore = document.createElement('button');
            const _tBI=(typeof T!=='undefined'&&T[currentLang])?T[currentLang]:T['es']; btnIgnore.textContent = _tBI.resumeIgnore||'Ignorar';
            Object.assign(btnIgnore.style, {background:'rgba(255,255,255,.12)',border:'none',color:'#fff',padding:'6px 12px',borderRadius:'8px',cursor:'pointer',fontSize:'.85rem'});
            btnIgnore.addEventListener('click', () => banner.remove());
            const btnContinue = document.createElement('button');
            const _tBC=(typeof T!=='undefined'&&T[currentLang])?T[currentLang]:T['es']; btnContinue.textContent = _tBC.profileContinue||'Continuar →';
            Object.assign(btnContinue.style, {background:'var(--gold)',border:'none',color:'#fff',padding:'6px 14px',borderRadius:'8px',cursor:'pointer',fontSize:'.85rem',fontWeight:'700'});
            btnContinue.addEventListener('click', () => { banner.remove(); showExam(0); });
            btns.appendChild(btnIgnore);
            btns.appendChild(btnContinue);
            banner.appendChild(msg);
            banner.appendChild(btns);
            document.body.prepend(banner);
          }
        }
      } catch(e) {}
    }

    // Warn before accidental page unload during exam
    window.addEventListener('beforeunload', (e) => {
      const hasData = Object.keys(state).length > 0 && Object.values(state).some(v => v && v.checked);
      if (hasData) {
        e.preventDefault();
        e.returnValue = '';
      }
    });

    renderTOC();
    formatTimer();
    updateProgress();

    // Apply saved language on load (also renders TOC, fuentes, TPS)
    applyLang(currentLang);
    // Render sources on details open (lazy — only when user expands)
    const fuentesDet = document.getElementById('fuentesSection');
    if (fuentesDet) fuentesDet.addEventListener('toggle', () => { if (fuentesDet.open) renderFuentes(); });

    // Show profile screen on first visit; skip on return if profile saved
    // Always show profile screen on load — allows changing profile or sharing device
    showProfileScreen();
    updateMobileNav();
  </script>

</body>
