              </div>
              <span class="res-btn-label" data-i18n="resBtnAntes">Antes de comenzar</span>
            </button>
            <button class="res-btn" type="button" onclick="showResourcePanel('como')">
              <div class="res-btn-icon blue">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 6h12M4 10h8M4 14h10" stroke="#1A4F8A" stroke-width="1.5" stroke-linecap="round"/></svg>
              </div>
              <span class="res-btn-label" data-i18n="resBtnComo">Cómo confesarte</span>
            </button>
            <button class="res-btn" type="button" onclick="showResourcePanel('despues')">
              <div class="res-btn-icon teal">
                <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M4 10l4 4 8-8" stroke="#0F6E56" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
