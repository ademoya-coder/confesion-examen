    .profile-note{font-size:.84rem;color:var(--muted);line-height:1.55;margin-bottom:18px;padding:12px 14px;background:var(--card-2);border-radius:12px;border:1px solid var(--line-soft)}

    /* ===== RESOURCE BUTTONS (profile screen extras) ===== */
    .res-section-divider{border:none;border-top:1px solid var(--line-soft);margin:18px 0 14px}
    .res-section-label{font-size:.76rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--muted);margin:0 0 10px;display:flex;align-items:center;gap:8px}
    .new-pill{display:inline-flex;align-items:center;padding:2px 8px;border-radius:999px;font-size:.68rem;font-weight:800;background:var(--soft);color:var(--accent);border:1px solid rgba(31,95,166,.18);letter-spacing:.03em}
    .res-btn-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px}
    .res-btn{
      background:var(--card);border:1px solid var(--line-soft);border-radius:16px;
      padding:14px 10px 12px;text-align:center;cursor:pointer;
      transition:.18s transform,.18s box-shadow,.18s border-color,.18s background;
