        // Show consent row and set consent pill
        const practiceConsentRow = document.getElementById('practiceConsentRow');
        if (practiceConsentRow) practiceConsentRow.classList.remove('hidden');
        const consentEl = document.getElementById('practiceConsent');
        if (consentEl) consentEl.value = 'si';
        const consentContainer = document.querySelector('[data-practice-gfield="practiceConsent"]')?.closest('.gravity-pill-options');
        if (consentContainer) {
          consentContainer.querySelectorAll('.gpill').forEach(p => p.className = 'gpill');
          const activeConsentBtn = consentContainer.querySelector('[data-value="si"]');
          if (activeConsentBtn) activeConsentBtn.classList.add('active-warn');
        }
        document.getElementById('practiceFreqType').value = 'habitual';
        renderPracticeFrequency();
        document.getElementById('practiceFrequency').value = 'Varias veces por semana';
        document.getElementById('practiceNoteWrap').classList.remove('hidden-soft');
        document.getElementById('practiceNoteToggle').textContent = '− Ocultar circunstancia breve';
        document.getElementById('practiceNote').value = 'en casa';
        updatePracticeProgress();
        evaluatePractice();
      };

      // 7. Reset / limpiar
      document.getElementById('practiceReset').onclick = () => {
        const cb = document.getElementById('practiceCheck');
