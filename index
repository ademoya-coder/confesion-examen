    function evaluatePractice() {
      const cb = document.getElementById('practiceCheck');
      const knowledge = document.getElementById('practiceKnowledge') ? document.getElementById('practiceKnowledge').value : '';
      const consent = document.getElementById('practiceConsent') ? document.getElementById('practiceConsent').value : '';
      const freqType = document.getElementById('practiceFreqType').value;
      const frequency = document.getElementById('practiceFrequency') ? document.getElementById('practiceFrequency').value.trim() : '';
      const note = document.getElementById('practiceNote') ? document.getElementById('practiceNote').value.trim() : '';
      const status = document.getElementById('practiceStatus');
      const preview = document.getElementById('practicePreview');
      const badge = document.getElementById('practiceGravityResult');

      if (!cb || !cb.checked) {
        practiceState.done = false;
        if (status) status.textContent = '';
        if (preview) preview.innerHTML = '<div class="small muted" data-i18n="step2PreviewPrompt">Marca la pregunta para empezar.</div>';
        updatePracticeContinue();
        return;
      }

      const result = gravityResult(knowledge, consent);
      if (badge) { badge.textContent = result.text; badge.className = 'gravity-result ' + result.tone; }

      // Show/hide consent row
      const consentRow = document.getElementById('practiceConsentRow');
      if (consentRow) consentRow.classList.toggle('hidden', !knowledge || knowledge === 'no');

      const gravDone = knowledge && (knowledge === 'no' || consent);
      if (!(gravDone && freqType && frequency)) {
        practiceState.done = false;
        const _tEP=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es']; if (status) { status.textContent = _tEP.practiceStatusIncomplete||'Completa las preguntas de discernimiento y la frecuencia.'; status.className = 'practice-status'; }
        if (preview) preview.innerHTML = '<div class="small muted">Tu nota aparecerá aquí cuando completes los campos.</div>';
        updatePracticeContinue();
        return;
      }

      practiceState.done = true;
      localStorage.setItem('ec_practice_done', '1');
      const _tEP2=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es']; if (status) { status.textContent = _tEP2.practiceStatusDone||'Listo. Ya sabes cómo funciona.'; status.className = 'practice-status ok'; }
      const _tPrev=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es']; if (preview) preview.innerHTML = '<div style="font-size:.88rem;font-weight:600;color:var(--gold);margin-bottom:6px">' + (_tPrev.practicePreviewLabel||'Tu nota quedaría así:') + '</div><div class="small">• ' + (_tPrev.step2PracticeQ||'Respondí con ira...') + ' <span class="muted">' + (result.text || '') + (frequency ? ' · ' + (_tPrev.freqTitle||'frecuencia') + ': ' + frequency : '') + (note ? ' · ' + (_tPrev.noteTitle||'circunstancia') + ': ' + note : '') + '</span></div>';
      updatePracticeContinue();
    }
