    .res-btn-icon{width:34px;height:34px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .res-btn-icon.amber{background:var(--gold-bg)}
    .res-btn-icon.blue{background:var(--soft)}
    .res-btn-icon.teal{background:var(--ok-bg)}
    .res-btn-label{font-size:.80rem;font-weight:700;color:var(--ink);line-height:1.25}
    .faq-row-btn{
      width:100%;background:var(--card);border:1px solid var(--line-soft);border-radius:14px;
      padding:13px 16px;display:flex;align-items:center;justify-content:space-between;
      cursor:pointer;font-family:inherit;appearance:none;margin-bottom:18px;
      transition:.15s border-color,.15s background;
    }
    .faq-row-btn:hover{border-color:var(--line);background:var(--card-2)}
    .faq-row-left{text-align:left}
    .faq-row-title{font-size:.90rem;font-weight:700;color:var(--ink);display:block}
    .faq-row-sub{font-size:.80rem;color:var(--muted);display:block;margin-top:2px}
    .faq-row-arrow{color:#9CB2C7;font-weight:900;font-size:1.15rem;flex-shrink:0;margin-left:12px}
    /* Resource panels */
    .res-panel-back{margin-bottom:18px}
    .res-acc-list{display:grid;gap:8px;margin-top:14px}
    .res-acc-item{border:1px solid var(--line-soft);border-radius:14px;overflow:hidden;background:var(--card-2)}
    .res-acc-item summary{cursor:pointer;padding:12px 15px;font-weight:600;color:var(--ink);font-size:.93rem;background:var(--card-2);list-style:none;display:flex;align-items:center;justify-content:space-between;gap:12px}
    .res-acc-item summary::-webkit-details-marker{display:none}
    .res-acc-item summary::after{content:"›";color:var(--gold);font-weight:900;font-size:1.1rem;transition:transform .2s;flex-shrink:0}
    .res-acc-item[open]>summary::after{transform:rotate(90deg)}
    .res-acc-body{padding:13px 15px;border-top:1px solid var(--line);font-size:.90rem;line-height:1.68;color:var(--ink)}
    .res-acc-body p{margin:0 0 10px}
    .res-acc-body p:last-child{margin:0}
    .res-acc-body ul{margin:6px 0 0;padding-left:18px;display:grid;gap:6px}
    .res-acc-body li{line-height:1.55}
    .res-prayer{background:var(--gold-bg);border-left:3px solid var(--gold-border);border-radius:0 12px 12px 0;padding:13px 15px;font-style:italic;color:var(--ink);font-size:.90rem;line-height:1.65;margin:10px 0 0}
    .res-step{display:flex;gap:12px;padding:13px 15px;border:1px solid var(--line-soft);border-radius:14px;background:var(--card);margin-bottom:8px}
    .res-step-num{width:28px;height:28px;border-radius:8px;background:var(--gold-bg);border:1px solid rgba(200,148,10,.22);color:var(--gold);font-size:.82rem;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:"Lora",Georgia,serif}
    .res-step-body{flex:1;min-width:0}
    .res-step-title{font-weight:700;font-size:.90rem;color:var(--ink);display:block;margin-bottom:4px}
    .res-step-desc{font-size:.86rem;color:var(--muted);line-height:1.55}
    .res-example{background:var(--bg-2);border:1px solid var(--line-soft);border-radius:10px;padding:10px 12px;margin-top:8px;font-size:.84rem;color:var(--muted);line-height:1.5}
    .res-example strong{color:var(--ink);font-weight:600}
    @media(max-width:520px){
      .res-btn-grid{gap:8px}
      .res-btn{padding:12px 6px 10px}
      .res-btn-label{font-size:.76rem}
    }
    @media(max-width:360px){
