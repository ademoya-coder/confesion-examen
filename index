        showModal((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalTermsTitle||'Términos pendientes';})(), (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalTermsBody||'Primero debes leer y aceptar el aviso de uso pastoral.';})(), [
          { label: 'Ir al inicio', cls: 'primary', action: showIntro }
        ]);
        return;
      }
      if (!practiceState.done) {
        showModal((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalStepPending||'Paso pendiente';})(), (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalStepPendingPractice||'Antes de iniciar el examen, debes completar el Paso 2: Ensayo guiado.';})(), [
          { label: 'Ir al ensayo', cls: 'primary', action: showPractice }
        ]);
        return;
      }
      if (targetStage === 'results' || targetStage === 'contrition' || targetStage === 'after') {
        showModal((()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalStepPending||'Paso pendiente';})(), (()=>{const t=(typeof T!='undefined'&&T[currentLang])?T[currentLang]:T['es'];return t.modalStepPendingExam||'Primero completa el examen guiado. Luego podrás ver tu lista, el acto de contrición y el cierre.';})(), [
