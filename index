    .profile-card.selected h3{color:var(--gold)}
    .profile-age{display:inline-block;padding:3px 8px;border-radius:999px;font-size:.72rem;font-weight:700;background:var(--bg-2);color:var(--muted);margin-bottom:6px;white-space:nowrap}
