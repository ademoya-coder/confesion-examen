    function updatePracticeProgress() {
      const cb = document.getElementById('practiceCheck');
      const feeling = document.getElementById('practiceFeeling')?.value;
      const freq = document.getElementById('practiceFrequency')?.value;
      const knowledge = document.getElementById('practiceKnowledge')?.value;
      const fields = [cb?.checked, !!knowledge, !!freq];
      const done = fields.filter(Boolean).length;
      const total = 3;
      const pct = Math.round((done / total) * 100);
      const bar = document.getElementById('practiceProgressBar');
      const label = document.getElementById('practiceProgressLabel');
      if (bar) bar.style.width = pct + '%';
      if (label) label.textContent = done + ' de ' + total;
      // Color the card when question is checked
      const card = document.getElementById('practiceQuestionCard');
      if (card) card.classList.toggle('is-checked', !!cb?.checked);
    }

    // ===== TOAST SYSTEM =====
    function showToast(msg, tone = '', duration = 3000) {
      const container = document.getElementById('toastContainer');
      const el = document.createElement('div');
      el.className = 'toast' + (tone ? ' ' + tone : '');
      el.textContent = msg;
      container.appendChild(el);
      requestAnimationFrame(() => { requestAnimationFrame(() => el.classList.add('show')); });
      setTimeout(() => {
        el.classList.remove('show');
        setTimeout(() => el.remove(), 300);
      }, duration);
    }

    // ===== MODAL SYSTEM =====
    function showModal(title, body, buttons) {
      document.getElementById('modalTitle').textContent = title;
      document.getElementById('modalBody').textContent = body;
      const actions = document.getElementById('modalActions');
      actions.innerHTML = '';
      buttons.forEach(btn => {
        const el = document.createElement('button');
        el.className = btn.cls || 'ghost';
        el.textContent = btn.label;
        el.addEventListener('click', () => {
          closeModal();
          btn.action && btn.action();
        });
        actions.appendChild(el);
      });
      document.getElementById('modalOverlay').classList.add('show');
    }
    function closeModal() {
      document.getElementById('modalOverlay').classList.remove('show');
    }
    document.getElementById('modalOverlay').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeModal();
    });

