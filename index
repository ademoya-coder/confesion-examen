<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Examen de conciencia para una buena confesión</title>
  <meta name="description" content="Guía para preparar una buena confesión. Con citas bíblicas y doctrinales. Privado, en tu dispositivo." />
  <meta property="og:title" content="Examen de conciencia para una buena confesión" />
  <meta property="og:description" content="Guía dinámica para preparar una confesión íntegra, clara y serena. Comunidad Cuerpo de Cristo." />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="Examen de conciencia — Cuerpo de Cristo" />
  <meta name="twitter:description" content="Guía para preparar una buena confesión. Con citas bíblicas y doctrinales." />
  <meta name="theme-color" content="#1A2535" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Examen de Conciencia" />
  <link rel="manifest" href="manifest.webmanifest" />
  <link rel="icon" href="icon-192.png" />
  <link rel="apple-touch-icon" href="icon-192.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#F2EDE4;
      --bg-2:#EDE7DC;
      --card:#FDFAF4;
      --card-2:#FAF6EE;
      --ink:#2A3340;
      --ink-2:#1E2830;
      --muted:#6B7280;
      --accent:#1F5FA6;
      --accent-2:#2D73BE;
      --gold:#8B6914;
      --gold-light:#FAC775;
      --gold-bg:#FFF8EC;
      --gold-border:#C8940A;
      --line:#D9D0C0;
      --line-soft:#E8E2D6;
      --ok:#2E6B3A;
      --ok-bg:#EEF7EE;
      --warn:#8B6914;
      --warn-bg:#FFF8E6;
      --soft:#EAF2FC;
      --soft-2:#F4F8FD;
      --terra:#8B4A2A;
      --terra-bg:#FDF0EB;
      --shadow-1:0 1px 3px rgba(42,51,64,.05),0 4px 12px rgba(42,51,64,.06);
      --shadow-2:0 2px 8px rgba(42,51,64,.07),0 8px 24px rgba(42,51,64,.08);
      --shadow-3:0 4px 16px rgba(42,51,64,.09),0 16px 40px rgba(42,51,64,.10);
      --shadow:var(--shadow-2);
      --radius:20px;
      --radius-sm:14px;
      --radius-xs:10px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth;background:var(--bg);overscroll-behavior-y:none}
    body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif;color:var(--ink);background:var(--bg);-webkit-text-size-adjust:100%}
    h1,h2,h3,h4{font-family:"Lora",Georgia,"Times New Roman",serif;font-weight:600;letter-spacing:-.01em}
    .hero h1{font-family:"Lora",Georgia,serif;font-style:italic}
    .wrap{max-width:1240px;margin:0 auto;padding:22px}
    .hero{background:radial-gradient(ellipse at top right, rgba(255,255,255,.06) 0%, transparent 60%), linear-gradient(150deg,#1A2535 0%, #243346 55%, #2D3E52 100%);color:#fff;border-radius:28px;padding:32px 28px;box-shadow:var(--shadow-3);overflow:hidden;border:1px solid rgba(255,255,255,.06)}
    .hero-grid{display:grid;grid-template-columns:140px 1fr;gap:22px;align-items:center}
    .brand{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:20px;padding:14px;display:flex;align-items:center;justify-content:center;min-height:140px;backdrop-filter:blur(4px)}
    .brand img{max-width:100%;max-height:118px;object-fit:contain}
    .eyebrow{display:inline-flex;padding:6px 14px;border-radius:999px;background:rgba(250,199,117,.12);border:1px solid rgba(250,199,117,.25);font-size:.78rem;font-weight:700;letter-spacing:.10em;text-transform:uppercase;color:rgba(250,199,117,.92)}
    .hero h1{font-size:clamp(1.9rem,3.8vw,3.4rem);line-height:1.08;margin:14px 0 12px;text-shadow:0 2px 12px rgba(0,0,0,.18)}
    .hero p{margin:0;max-width:680px;font-size:1.12rem;line-height:1.65;color:rgba(255,255,255,.78);font-style:italic}
    .chips{display:flex;flex-wrap:wrap;gap:10px;margin:16px 0 0}
    .chip{
      display:inline-flex;align-items:center;gap:7px;
      padding:7px 14px;border-radius:999px;
      background:rgba(250,199,117,.10);
      border:1px solid rgba(250,199,117,.20);
      font-size:.84rem;font-weight:600;line-height:1.3;color:rgba(255,255,255,.80);
      pointer-events:none;user-select:none;box-shadow:none;
      white-space:nowrap;
    }
    .chip::before{
      content:"";
      width:5px;height:5px;border-radius:999px;
      background:rgba(250,199,117,.70);
      flex:0 0 5px;
    }
    .chip strong{font-weight:700}
    .side-note{margin-top:14px;padding:13px 15px;border-radius:14px;border:1px solid var(--line-soft);background:var(--bg)}
    .side-note.app{background:var(--bg);border-color:var(--line-soft)}
    .side-note.privacy{background:var(--bg);border-color:var(--line-soft)}
    .side-note p{margin:.35rem 0 0}
    .side-note strong{color:var(--ink)}
    .side-action{margin-top:12px}
    .link-inline{color:var(--accent);font-weight:800;text-decoration:none}
    .link-inline:hover{text-decoration:underline}
    .microcite{margin-top:10px;padding:10px 12px;border-radius:12px;background:var(--bg-2);border:1px solid var(--line-soft);color:var(--muted);font-size:.84rem;line-height:1.5;font-style:italic}
    .microcite strong{color:var(--gold);font-style:normal}
    .doctrine-accordion{margin-top:10px;border:1px solid var(--line-soft);border-radius:12px;overflow:hidden;background:var(--bg-2)}
    .doctrine-accordion summary{cursor:pointer;padding:10px 12px;font-weight:600;color:var(--gold);background:var(--bg-2)}
    .doctrine-body{padding:12px 13px;border-top:1px solid var(--line);display:grid;gap:10px}
    .doctrine-body .small{margin:0}
    .gravity-result{margin-top:8px;display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:999px;background:var(--soft);border:1px solid var(--line-soft);color:var(--accent);font-size:.82rem;font-weight:600}
    .gravity-result.warn{background:var(--gold-bg);border-color:rgba(200,148,10,.25);color:var(--gold)}
    .gravity-result.ok{background:var(--ok-bg);border-color:rgba(46,107,58,.25);color:var(--ok)}
    .helper-text{font-size:.84rem;color:var(--muted);line-height:1.45;margin-top:7px}
    .field-card{padding:12px;border:1px solid var(--line-soft);border-radius:13px;background:var(--bg)}
    .field-card h5{margin:0 0 8px;font-size:.9rem}
    .field-stack{display:grid;gap:10px}
    .source-links li{margin-bottom:12px}
    .source-links a{color:var(--accent);font-weight:800;text-decoration:none}
    .source-links a:hover{text-decoration:underline}
    .grid{display:grid;grid-template-columns:340px 1fr;gap:24px;margin-top:24px;align-items:start}
    .main-content{min-width:0}
    .side,.panel,.card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow-2)}
    .side{background:var(--card-2);border-color:var(--line-soft);box-shadow:var(--shadow-1)}
    .card{background:var(--card-2);border-color:var(--line-soft);box-shadow:none}
    .callout{background:linear-gradient(135deg,var(--gold-bg) 0%,#FFFDF7 100%);border-color:rgba(200,148,10,.22);border-left:3px solid var(--gold)}
    .side{position:sticky;top:16px;padding:20px}
    .panel{padding:24px}
    .card{padding:18px}
    h2,h3,h4{margin:0 0 12px;color:var(--ink-2)}
    .muted{color:var(--muted)}
    .small{font-size:.94rem;line-height:1.6}
    .section-title{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:10px}
    .ref{display:inline-flex;align-items:center;padding:6px 12px;border-radius:999px;background:var(--gold-bg);color:var(--gold);border:1px solid rgba(200,148,10,.25);font-size:.80rem;font-weight:700}
    .meta{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin:18px 0}
    .meta .box{padding:14px;border-radius:16px;background:var(--bg-2);border:1px solid var(--line-soft)}
    .timer{font-size:1.95rem;font-weight:700;letter-spacing:.02em;font-family:"Lora",Georgia,serif;color:var(--ink-2)}
    .controls,.nav-buttons{display:flex;flex-wrap:wrap;gap:10px}
    button,.btn{border:none;cursor:pointer;text-decoration:none;border-radius:12px;padding:12px 16px;font-weight:600;font-size:.94rem;transition:.18s transform,.18s opacity,.18s background,.18s box-shadow;appearance:none;font-family:inherit;letter-spacing:.01em}
    button:hover,.btn:hover{transform:translateY(-1px)}
    button:disabled{opacity:.45;cursor:not-allowed;transform:none}
    .primary{background:linear-gradient(135deg,#1A4F8A 0%,#1F5FA6 100%);color:#fff;box-shadow:0 2px 8px rgba(31,95,166,.30)}
    .secondary{background:var(--gold-bg);color:var(--gold);border:1px solid rgba(200,148,10,.22)}
    .ghost{background:var(--card);border:1px solid var(--line);color:var(--ink)}
    .danger{background:var(--terra-bg);color:var(--terra);border:1px solid rgba(139,74,42,.20)}
    .progress{height:10px;background:var(--bg-2);border-radius:999px;overflow:hidden;border:1px solid var(--line-soft);margin-top:12px}
    .progress > span{display:block;height:100%;width:0%;background:linear-gradient(90deg,var(--gold) 0%,#C8940A 100%);transition:width .3s ease}
    .legend{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
    .legend span{font-size:.83rem;padding:7px 10px;border-radius:999px;background:var(--card-2);border:1px solid var(--line-soft);color:var(--muted);font-weight:600}
    .stepper{display:flex;flex-direction:column;gap:12px;margin-top:14px}
    .step{
      position:relative;display:flex;align-items:center;gap:14px;
      padding:14px 14px 14px 12px;border-radius:16px;border:1px solid var(--line-soft);
      background:var(--card);
      cursor:pointer;text-decoration:none;color:inherit;
      box-shadow:var(--shadow-1);
      transition:.18s transform,.18s box-shadow,.18s border-color,.18s background;
    }
    .step:hover{transform:translateY(-1px);box-shadow:var(--shadow-2);border-color:var(--line)}
    .step.active{
      border-color:var(--gold-border);
      background:var(--gold-bg);
      box-shadow:0 4px 16px rgba(139,105,20,.12);
    }
    .step.done{
      border-color:var(--line-soft);
      background:var(--card-2);
      opacity:.85;
    }
    .step.locked{
      opacity:.72;
      cursor:not-allowed;
    }
    .step.locked:hover{
      transform:none;
      box-shadow:0 8px 24px rgba(18,50,84,.06);
      border-color:var(--line);
    }
    .step-index{
      width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;
      background:var(--bg-2);
      border:1px solid var(--line);color:var(--gold);font-size:.88rem;font-weight:600;flex:0 0 38px;
      font-family:"Lora",Georgia,serif;
    }
    .step.active .step-index{
      background:linear-gradient(135deg,var(--gold) 0%,#C8940A 100%);
      border-color:transparent;color:#fff;
      box-shadow:0 4px 12px rgba(139,105,20,.30);
    }
    .step-copy{min-width:0;flex:1}
    .step strong{display:block;font-size:.95rem;line-height:1.2;color:var(--ink-2);font-weight:600}
    .step-sub{display:block;font-size:.84rem;color:var(--muted);margin-top:4px}
    .pill{
      display:inline-flex;align-items:center;justify-content:center;
      padding:5px 10px;border-radius:999px;font-size:.75rem;font-weight:600;
      background:var(--bg);border:1px solid var(--line-soft);color:var(--muted);margin-top:6px;
      align-self:flex-start;
    }
    .step.active .pill{background:rgba(139,105,20,.10);border-color:rgba(200,148,10,.25);color:var(--gold)}
    .step-chevron{color:#9cb2c7;font-weight:900;font-size:1rem;flex:0 0 auto}
    .two-col{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
    .question-list{display:grid;gap:14px;margin-top:14px}
    .q{padding:16px 18px;border:1px solid var(--line-soft);border-radius:16px;background:var(--card);transition:.2s background,.2s border-color,.2s box-shadow}
    .q-head{display:flex;gap:14px;align-items:flex-start}
    .q-head input[type=checkbox]{margin-top:4px;transform:scale(1.3);accent-color:var(--gold);cursor:pointer}
    .q label{font-weight:600;line-height:1.55;display:block;cursor:pointer;color:var(--ink)}
    .q .cite{display:block;font-size:.80rem;color:var(--gold);opacity:.75;margin-top:5px;font-style:italic}
    .q .details{display:grid;grid-template-columns:minmax(0,1.15fr) minmax(260px,.85fr);gap:12px;margin-top:12px;align-items:start}
    .q select,.q input[type=text], .q textarea{width:100%;padding:10px 12px;border:1px solid var(--line);border-radius:13px;background:#fff;font:inherit;color:var(--ink)}
    .q textarea{min-height:72px;resize:vertical}
    .q .secondary-row{grid-column:1/-1;display:grid;gap:8px}
    .optional-toggle{display:inline-flex;align-items:center;justify-content:center;gap:8px;align-self:flex-start}
    .optional-panel.hidden-soft{display:none}
    .compact-input{min-height:44px}
    .gravity-card .gravity-result{align-self:flex-start}
    .frequency-card .helper-text{margin-top:2px}
    .gravity-controls{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px}
    .frequency-controls{display:grid;gap:8px}
    .q .field-card{padding:10px 11px}
    .q h5{font-size:.88rem;margin:0 0 6px}
    .microcite{padding:9px 10px;font-size:.84rem;line-height:1.4}
    .doctrine-accordion summary{padding:9px 11px;font-size:.9rem}
    .helper-text{font-size:.82rem;line-height:1.42}
    .gravity-result{margin-top:8px;padding:7px 10px;font-size:.8rem}
    .q{padding:14px 16px}
    .q.is-checked{background:var(--gold-bg);border-color:rgba(200,148,10,.30);border-left:3px solid var(--gold);box-shadow:0 2px 8px rgba(139,105,20,.08)}
    .q.is-complete{background:var(--ok-bg);border-color:rgba(46,107,58,.28);border-left:3px solid var(--ok)}
    .hero h1,.hero p,.step strong,.step-sub,.result-item,.source-links li,.source-links a,.q label,.q .cite,.callout,.compact-tip,.checkline,.side-note p,.microcite,.helper-text{overflow-wrap:anywhere}
    .controls > .btn,.controls > button,.nav-buttons > .btn,.nav-buttons > button{min-width:0}
    .toolbar{display:flex;gap:10px;flex-wrap:wrap;justify-content:space-between;align-items:center;margin:24px 0 0}
    .result{padding:18px;border-radius:16px;background:var(--card-2);border:1px solid var(--line-soft)}
    .result-list{display:grid;gap:12px;margin-top:14px}
    .result-item{padding:14px 15px;border-radius:14px;background:var(--card);border:1px solid var(--line-soft)}
    .callout{padding:15px 16px;border-radius:16px}
    .inline-note{max-width:620px;font-size:.93rem;color:var(--muted);line-height:1.6}
    .summary-box{padding:15px 16px;border-radius:14px;background:var(--gold-bg);border:1px solid rgba(200,148,10,.20);border-left:3px solid var(--gold)}
    .hidden{display:none !important}
    .practice-grid{display:grid;gap:14px;margin-top:16px}
    .practice-learn{display:grid;grid-template-columns:1fr;gap:14px;margin-top:16px}
    .practice-example{padding:16px;border-radius:18px;border:1px solid var(--line-soft);background:var(--card)}
    .practice-preview{padding:14px;border-radius:13px;background:var(--bg-2);border:1px dashed var(--gold-border);margin-top:12px}
    .practice-bullets{display:grid;gap:10px;margin-top:10px}
    .practice-bullet{padding:12px 13px;border-radius:13px;background:var(--bg-2);border:1px solid var(--line-soft)}
    .practice-mini{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}
    .practice-card{padding:18px;border-radius:18px;border:1px solid var(--line-soft);background:var(--card)}
    .practice-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:12px}
    .field-label{font-size:.81rem;font-weight:700;letter-spacing:.04em;color:var(--gold);margin-bottom:6px}
    .choice-group{display:flex;flex-wrap:wrap;gap:8px}
    .choice-btn{padding:9px 12px;border-radius:999px;border:1px solid var(--line-soft);background:var(--card);color:var(--accent);font-size:.88rem;font-weight:700;cursor:pointer}
    .choice-btn.active{background:var(--accent);color:#fff;border-color:var(--accent)}
    .practice-status{margin-top:10px;font-size:.9rem;color:var(--muted)}
    .practice-status.ok{color:var(--ok);font-weight:800}
    .practice-status.warn{color:var(--warn);font-weight:800}
    .compact-tip{margin-bottom:16px;padding:12px 15px;border-radius:13px;background:var(--bg-2);border:1px solid var(--line-soft);border-left:3px solid var(--gold-border);color:var(--muted);font-size:.90rem;line-height:1.6}
    details.terms{margin-top:18px;border:1px solid var(--line-soft);border-radius:16px;overflow:hidden;background:var(--card-2)}
    details.terms summary{cursor:pointer;padding:14px 16px;font-weight:600;background:var(--bg-2);color:var(--ink)}
    details.terms .content{padding:16px}
    .checkline{display:flex;gap:10px;align-items:flex-start;padding:14px 16px;border-radius:14px;background:var(--gold-bg);border:1px solid rgba(200,148,10,.22);margin-top:16px}
    .checkline input{margin-top:3px;transform:scale(1.1)}
    .kicker{font-size:.75rem;letter-spacing:.10em;text-transform:uppercase;color:var(--gold);font-weight:700}
    .footer-note{padding:22px 0 60px;color:var(--muted);font-size:.88rem;border-top:1px solid var(--line-soft);margin-top:8px}
    @media (max-width:1366px){
      .wrap{max-width:1200px}
      .grid{grid-template-columns:312px minmax(0,1fr);gap:20px}
      .hero h1{font-size:3.05rem}
    }
    @media (max-width:1280px){
      .q .details,.practice-learn{grid-template-columns:1fr}
      .practice-mini{grid-template-columns:repeat(2,minmax(0,1fr))}
    }
    @media (max-width:1180px){
      .grid{grid-template-columns:290px minmax(0,1fr);gap:18px}
      .hero-grid{grid-template-columns:124px minmax(0,1fr)}
      .hero p{max-width:100%}
      .section-title{align-items:flex-start}
    }
    @media (max-width:1020px){
      .grid,.hero-grid,.two-col,.meta,.q .details,.practice-row,.practice-learn{grid-template-columns:1fr}
      .wrap{padding:16px max(16px, env(safe-area-inset-right)) 18px max(16px, env(safe-area-inset-left))}
      .hero{padding:22px}
      .hero-grid{gap:18px;align-items:flex-start}
      .hero h1{font-size:2.25rem;line-height:1.06}
      .hero p{font-size:1rem}
      .brand{min-height:118px;max-width:140px}
      .chips{gap:8px}
      .chip{font-size:.86rem;padding:8px 11px}
      .side{position:static;order:2;padding:18px}
      .main-content{order:1}
      .panel{padding:18px}
      .section-title{gap:12px}
      .step{padding:14px}
      .step-index{width:38px;height:38px;border-radius:12px;flex-basis:38px}
      .step strong{font-size:.96rem}
      .step-sub{font-size:.82rem}
      .controls,.nav-buttons,.toolbar{gap:8px}
      .controls > *, .nav-buttons > *{flex:1 1 calc(50% - 8px)}
      button,.btn{min-height:46px}
      .side-note.app,.side-note.privacy{margin-top:12px}
    }
    @media (max-width:820px){
      .hero{border-radius:26px}
      .hero-grid{gap:16px}
      .brand{max-width:128px;min-height:108px;padding:10px}
      .meta{grid-template-columns:1fr}
      .section-title{flex-direction:column;align-items:flex-start}
      .ref{align-self:flex-start}
      .controls > *, .nav-buttons > *{flex:1 1 100%}
      .toolbar{flex-direction:column;align-items:stretch}
      .toolbar > *{width:100%}
    }
    @media (max-width:720px){
      body{font-size:16px}
      .wrap{padding:12px max(12px, env(safe-area-inset-right)) 16px max(12px, env(safe-area-inset-left))}
      .hero{border-radius:24px;padding:18px}
      .hero h1{font-size:2rem}
      .brand{max-width:122px;min-height:102px;padding:10px}
      .chips{flex-wrap:wrap}
      .chip{white-space:nowrap}
      .grid{gap:16px;margin-top:18px}
      .side,.panel,.card{border-radius:20px}
      .panel{padding:16px}
      .box,.callout,.side-note{border-radius:16px}
      .step{border-radius:18px;gap:12px}
      .step-copy{display:grid;gap:4px}
      .step strong{font-size:.94rem}
      .step-sub{font-size:.81rem}
      .ref{font-size:.8rem;padding:8px 10px}
      .timer{font-size:1.6rem}
      .q{padding:14px 16px}
    .q.is-checked{background:var(--gold-bg);border-color:rgba(200,148,10,.30);border-left:3px solid var(--gold);box-shadow:0 2px 8px rgba(139,105,20,.08)}
    .q.is-complete{background:var(--ok-bg);border-color:rgba(46,107,58,.28);border-left:3px solid var(--ok)}
      .q label{font-size:1rem}
      .q .cite{font-size:.82rem}
      .field-card{padding:10px}
      .helper-text,.small{font-size:.88rem}
