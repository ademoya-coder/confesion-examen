    .slim-flag-btn{width:30px;height:26px;border-radius:7px;border:none;font-size:1rem;cursor:pointer;background:transparent;opacity:.45;transition:.15s;display:flex;align-items:center;justify-content:center;line-height:1}
    .slim-flag-btn.active{background:rgba(250,199,117,.18);opacity:1;box-shadow:0 0 0 1.5px rgba(250,199,117,.40)}
    .slim-menu-btn{padding:5px 10px;border-radius:9px;border:1px solid rgba(255,255,255,.18);background:transparent;color:rgba(255,255,255,.65);font-size:.78rem;font-weight:700;cursor:pointer;letter-spacing:.03em;transition:.15s;white-space:nowrap}
    .slim-menu-btn:hover{background:rgba(255,255,255,.08);color:rgba(255,255,255,.88)}
