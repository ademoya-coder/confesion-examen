    @media (prefers-color-scheme: dark){
      :root{
        --bg:#1A1F27;
        --bg-2:#1E242D;
        --card:#242B36;
        --card-2:#202830;
        --ink:#E8E2D8;
        --ink-2:#F0EBE3;
        --muted:#8A8F99;
        --line:#35404F;
        --line-soft:#2C3542;
        --gold:#D4A84B;
        --gold-light:#FAC775;
        --gold-bg:rgba(139,105,20,.15);
        --gold-border:#8B6914;
        --ok:#4CAF75;
        --ok-bg:rgba(46,107,58,.18);
        --warn-bg:rgba(139,105,20,.15);
        --soft:rgba(31,95,166,.18);
        --soft-2:rgba(31,95,166,.08);
        --terra:#C4775A;
        --terra-bg:rgba(139,74,42,.18);
        --shadow-1:0 1px 3px rgba(0,0,0,.25),0 4px 12px rgba(0,0,0,.20);
        --shadow-2:0 2px 8px rgba(0,0,0,.28),0 8px 24px rgba(0,0,0,.22);
        --shadow-3:0 4px 16px rgba(0,0,0,.32),0 16px 40px rgba(0,0,0,.25);
      }
      html, body { background:var(--bg); }
      .hero{background:linear-gradient(150deg,#0D1520 0%,#141E2D 55%,#1A2535 100%)}
      /* Cards & panels */
      .card, .side, .panel { background:var(--card); border-color:var(--line); }
      .callout { background:linear-gradient(135deg,var(--gold-bg) 0%,rgba(36,43,54,.9) 100%); border-color:rgba(139,105,20,.30); }
      .compact-tip { background:var(--bg-2); border-color:var(--line); color:var(--muted); }
      .summary-box { background:var(--gold-bg); border-color:rgba(139,105,20,.25); }
      .result { background:var(--card-2); border-color:var(--line-soft); }
      .result-item { background:var(--card); border-color:var(--line-soft); }
      /* Questions */
      .q { background:var(--card); border-color:var(--line-soft); }
      .q.is-checked { background:var(--gold-bg); border-color:rgba(200,148,10,.30); }
      .q.is-complete { background:var(--ok-bg); border-color:rgba(46,107,58,.22); }
      .q select,.q input[type=text],.q textarea { background:var(--bg-2);color:var(--ink);border-color:var(--line); }
      .field-card { background:var(--bg-2); border-color:var(--line-soft); }
      .doctrine-accordion { background:var(--bg-2); border-color:var(--line-soft); }
      .doctrine-accordion summary { background:var(--bg-2); color:var(--gold); }
      .microcite { background:var(--bg-2); border-color:var(--line-soft); }
      /* Gravity pills */
      .gpill { background:var(--bg-2);border-color:var(--line);color:var(--ink); }
      .gpill:hover { background:var(--gold-bg);border-color:var(--gold-border);color:var(--gold); }
      .gravity-result { background:var(--soft); color:var(--accent); }
      .gravity-result.warn { background:var(--gold-bg); color:var(--gold); }
      .gravity-result.ok { background:var(--ok-bg); color:var(--ok); }
      /* Buttons */
      button.ghost,.btn.ghost { background:var(--card); border-color:var(--line); color:var(--ink); }
      button.secondary,.btn.secondary { background:var(--gold-bg); color:var(--gold); border-color:rgba(200,148,10,.25); }
      button.danger,.btn.danger { background:var(--terra-bg); color:var(--terra); }
      /* TOC steps */
      .step { background:var(--card); border-color:var(--line-soft); }
      .step.active { background:var(--gold-bg); border-color:var(--gold-border); }
      .step.done { background:var(--card-2); }
      .step-index { background:var(--bg-2); border-color:var(--line); }
      /* Section chips */
      .sec-chip { background:var(--card); border-color:var(--line-soft); color:var(--muted); }
      .sec-chip.done { background:var(--ok-bg); color:var(--ok); }
      .sec-chip.cur { background:var(--gold-bg); color:var(--gold); border-color:var(--gold-border); }
      /* Resource panels */
      .res-acc-item { background:var(--card-2); border-color:var(--line-soft); }
      .res-acc-item summary { background:var(--card-2); color:var(--ink); }
