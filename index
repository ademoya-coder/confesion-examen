              </div>
              <div style="background:#2A3340;border-radius:8px;padding:9px 10px">
                <p style="font-size:.78rem;font-weight:600;color:rgba(255,255,255,.9);margin:0 0 4px">Android</p>
                <p style="font-size:.72rem;color:rgba(255,255,255,.5);margin:0;line-height:1.5">Chrome → ⋮ menú → Agregar a inicio</p>
              </div>
            </div>
            <button class="secondary hidden" id="installApp" type="button" style="width:100%;margin-top:2px">Instalar ahora</button>
          </div>
        </div>

        <div class="side-note privacy small" style="border-top:none;margin-top:8px">
          <p style="margin:0;font-size:.79rem;color:var(--muted);line-height:1.55">
            <svg width="11" height="11" viewBox="0 0 12 12" style="display:inline;vertical-align:middle;margin-right:4px;opacity:.5"><rect x="1" y="4" width="10" height="7" rx="1.5" fill="none" stroke="#6B7280" stroke-width="1.2"/><path d="M4 4V3a2 2 0 014 0v1" fill="none" stroke="#6B7280" stroke-width="1.2"/></svg>
            Lo que marcas queda en este dispositivo. No se envía a servidores.
          </p>
        </div>
      </aside>

      <main class="main-content">
        <!-- PROFILE SELECTION SCREEN -->
        <section class="panel hidden" id="profilePanel">
          <div class="section-title" style="margin-bottom:6px">
            <div>
              <div class="kicker" id="profileKicker">Antes de comenzar</div>
              <h2 id="profileTitle">¿Quién eres?</h2>
            </div>
          </div>
          <p class="small muted" id="profileSubtitle" style="margin:0 0 18px">Elige tu perfil para que el examen sea adecuado a tu situación de vida.</p>

          <div class="profile-cards" id="profileCards">
            <button class="profile-card" id="pcAdultMarried" type="button" onclick="selectProfile('adultMarried')">
              <div class="profile-card-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="6.5" cy="6" r="2.5" stroke="#FAC775" stroke-width="1.3"/><circle cx="13.5" cy="6" r="2.5" stroke="#FAC775" stroke-width="1.3"/><path d="M1.5 18c0-2.8 2.2-5 5-5h7c2.8 0 5 2.2 5 5" stroke="#FAC775" stroke-width="1.3" stroke-linecap="round"/></svg>
              </div>
              <div class="profile-age" id="profileAgeMarried">20 años o más</div>
              <h3 id="profileLabelMarried">Adulto Casado</h3>
            </button>
            <button class="profile-card" id="pcAdultSingle" type="button" onclick="selectProfile('adultSingle')">
              <div class="profile-card-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="6" r="3.5" stroke="#FAC775" stroke-width="1.4"/><path d="M3 18c0-3.9 3.1-7 7-7s7 3.1 7 7" stroke="#FAC775" stroke-width="1.4" stroke-linecap="round"/></svg>
              </div>
              <div class="profile-age" id="profileAgeSingle">20 años o más</div>
              <h3 id="profileLabelSingle">Adulto Soltero</h3>
            </button>
            <button class="profile-card" id="pcTeen" type="button" onclick="selectProfile('teen')">
              <div class="profile-card-icon">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="6" r="3" stroke="#FAC775" stroke-width="1.4"/><path d="M4 18c0-3.3 2.7-6 6-6s6 2.7 6 6" stroke="#FAC775" stroke-width="1.4" stroke-linecap="round"/><path d="M7 10.5l3 4 3-4" stroke="#FAC775" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
              <div class="profile-age" id="profileAgeTeen">14 a 19 años</div>
              <h3 id="profileLabelTeen">Adolescente</h3>
            </button>
          </div>

          <p class="profile-note" id="profileNote">El perfil se guarda en tu dispositivo. Puedes cambiarlo iniciando una nueva sesión.</p>

          <hr class="res-section-divider">
          <div class="res-section-label">
            <span data-i18n="resLabel">Recursos</span>
            <span class="new-pill" data-i18n="resPillNew">NUEVO</span>
          </div>
          <div class="res-btn-grid">
            <button class="res-btn" type="button" onclick="showResourcePanel('antes')">
