    }
    .sec-chip.done{background:var(--ok-bg);color:var(--ok);border-color:rgba(46,107,58,.28)}
    .sec-chip.cur{background:var(--gold-bg);color:var(--gold);border-color:var(--gold-border)}
    .sec-chip-dot{width:6px;height:6px;border-radius:50%;background:currentColor;opacity:.6;flex-shrink:0}
