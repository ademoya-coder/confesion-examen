    function applyI18n(lang) {
      const t = T[lang] || T['es'];
      // Text nodes
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (t[key] !== undefined) el.textContent = t[key];
      });
      // HTML content (rich text with tags)
      document.querySelectorAll('[data-i18n-html]').forEach(el => {
        const key = el.getAttribute('data-i18n-html');
        if (t[key] !== undefined) el.innerHTML = t[key];
      });
      // Placeholder attributes
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const key = el.getAttribute('data-i18n-placeholder');
        if (t[key] !== undefined) el.placeholder = t[key];
      });
      // Select option translations (practiceFreqType)
      const freqSel = document.getElementById('practiceFreqType');
      if (freqSel) {
        freqSel.options[0].textContent = t.freqPlaceholder || freqSel.options[0].textContent;
        if (freqSel.options[1]) freqSel.options[1].textContent = t.freqOneOff || freqSel.options[1].textContent;
        if (freqSel.options[2]) freqSel.options[2].textContent = t.freqHabitual || freqSel.options[2].textContent;
      }
    }

