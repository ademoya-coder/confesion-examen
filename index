    function hideAllPanels() {
      Object.values(panels).forEach(panel => panel.classList.add('hidden'));
    }

    function scrollTopPage() {
      if (window.innerWidth <= 1020) {
        const wrap = document.querySelector('.wrap');
        if (wrap) wrap.scrollTop = 0;
      } else {
        window.scrollTo({ top: 0, behavior: 'instant' });
      }
    }

    function transitionTo(showFn) {
      const active = Object.values(panels).find(p => !p.classList.contains('hidden'));
      if (active) {
        active.classList.add('fading');
        setTimeout(() => {
          active.classList.remove('fading');
          showFn();
          requestAnimationFrame(() => scrollTopPage());
        }, 160);
      } else {
        showFn();
        requestAnimationFrame(() => scrollTopPage());
      }
    }

    function totalMilestones() {
      return sections.length + 3;
    }

    function currentMilestone() {
      if (currentView === 'intro') return 0;
      if (currentView === 'practice') return 0;
      if (currentView === 'exam') return 1 + current;
      if (currentView === 'results') return 1 + sections.length;
      if (currentView === 'contrition') return 2 + sections.length;
      if (currentView === 'after') return 3 + sections.length;
      return 0;
    }

    function progressLabel() {
      const tPL = (typeof T!=='undefined'&&T[currentLang])?T[currentLang]:T['es'];
      if (currentView === 'intro') return tPL.tocPrep || 'Preparación';
      if (currentView === 'practice') return tPL.tocPractice || 'Práctica guiada';
      if (currentView === 'exam') return (tPL.step2Kicker||'Paso 3').replace(/\d/,'3') + ' · ' + ({es:'Sección',en:'Section',pt:'Seção'}[currentLang]||'Sección') + ' ' + (current + 1) + ' / ' + sections.length;
      if (currentView === 'results') return tPL.step4Title || 'Mi lista para la confesión';
      if (currentView === 'contrition') return tPL.step5Title || 'Acto de contrición';
      if (currentView === 'after') return tPL.step6Title || 'Después de confesarte';
      return tPL.tocPrep || 'Preparación';
    }

    function updateProgress() {
      const total = totalMilestones();
      const now = currentMilestone();
      const pct = Math.round((now / total) * 100);
      document.getElementById('progressText').textContent = pct + '%';
      document.getElementById('bar').style.width = pct + '%';
      document.getElementById('progressLabel').textContent = progressLabel();
    }

    function renderTOC() {
      const t = (typeof I18N !== 'undefined' && I18N[currentLang]) ? I18N[currentLang] : I18N['es'];
      const stageIndex = { intro:1, practice:2, exam:3, results:4, contrition:5, after:6 };
      const currentStage = currentView === 'exam' ? 'exam' : currentView;
      const examSub = currentView === 'exam'
        ? `${t.tocExamProgress} ${current + 1}/${sections.length}`
        : t.tocExamSub;
      const examPill = currentView === 'exam'
        ? `${t.tocExamProgress} ${current + 1}/${sections.length}`
        : `${sections.length} ${t.tocExamPill}`;
      const items = [
        { id: 'intro',      title: t.tocPrep,       sub: t.tocPrepSub,       pill: t.tocPrepPill,       unlocked: true },
        { id: 'practice',   title: t.tocPractice,   sub: t.tocPracticeSub,   pill: t.tocPracticePill,   unlocked: hasAcceptedTerms() || currentStage === 'practice' },
        { id: 'exam',       title: t.tocExam,       sub: examSub,            pill: examPill,            unlocked: canOpenExamFlow() || currentStage === 'exam' },
        { id: 'results',    title: t.tocResults,    sub: t.tocResultsSub,    pill: t.tocResultsPill,    unlocked: canOpenExamFlow() || currentStage === 'results' },
        { id: 'contrition', title: t.tocContrition, sub: t.tocContritionSub, pill: t.tocContritionPill, unlocked: canOpenExamFlow() || currentStage === 'contrition' },
        { id: 'after',      title: t.tocAfter,      sub: t.tocAfterSub,      pill: t.tocAfterPill,      unlocked: canOpenExamFlow() || currentStage === 'after' }
      ];

      toc.innerHTML = items.map(item => {
        const active = item.id === currentStage;
        const done = stageIndex[item.id] < stageIndex[currentStage];
        const locked = !item.unlocked;
        return `
          <a href="#" class="step ${active ? 'active' : ''} ${done ? 'done' : ''} ${locked ? 'locked' : ''}" data-stage="${item.id}" data-locked="${locked ? 'true' : 'false'}" aria-current="${active ? 'step' : 'false'}" aria-disabled="${locked ? 'true' : 'false'}">
            <span class="step-index">${stageIndex[item.id]}</span>
            <span class="step-copy">
              <strong>${t.tocStepPrefix} ${stageIndex[item.id]}. ${item.title}</strong>
              <span class="step-sub">${item.sub}</span>
              <span class="pill">${item.pill}</span>
            </span>
            <span class="step-chevron">›</span>
          </a>
        `;
      }).join('');

      toc.querySelectorAll('[data-stage]').forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const stage = link.dataset.stage;
          const locked = link.dataset.locked === 'true';

          if (locked) {
            explainLockedStep(stage);
            return;
          }

          if (stage === 'intro') showIntro();
          else if (stage === 'practice') showPractice();
          else if (stage === 'exam') showExam(current);
          else if (stage === 'results') showResults();
          else if (stage === 'contrition') showContrition();
          else if (stage === 'after') showAfter();
        });
      });
    }

    
